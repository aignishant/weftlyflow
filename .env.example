# Weftlyflow environment variables
# Copy to .env and adjust.

# ---- core ----
WEFTLYFLOW_ENV=development           # development | production | test
WEFTLYFLOW_LOG_LEVEL=debug           # debug | info | warning | error
WEFTLYFLOW_LOG_FORMAT=console        # console | json
WEFTLYFLOW_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ---- data ----
WEFTLYFLOW_DATABASE_URL=sqlite+aiosqlite:///./data/weftlyflow.db
# WEFTLYFLOW_DATABASE_URL=postgresql+psycopg://weftlyflow:weftlyflow@localhost:5432/weftlyflow

WEFTLYFLOW_REDIS_URL=redis://localhost:6379/0
WEFTLYFLOW_CELERY_BROKER_URL=redis://localhost:6379/0
WEFTLYFLOW_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ---- crypto ----
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WEFTLYFLOW_ENCRYPTION_KEY=
# For rotation (comma-separated old keys, oldest last):
# WEFTLYFLOW_ENCRYPTION_KEY_OLD_KEYS=

# ---- server ----
WEFTLYFLOW_HOST=0.0.0.0
WEFTLYFLOW_PORT=5678
WEFTLYFLOW_PUBLIC_URL=http://localhost:5678
WEFTLYFLOW_CORS_ORIGINS=http://localhost:5173

# ---- features ----
WEFTLYFLOW_REGISTRATION_ENABLED=true
WEFTLYFLOW_MFA_REQUIRED=false
WEFTLYFLOW_COMMUNITY_NODES_DIR=

# ---- observability ----
WEFTLYFLOW_METRICS_ENABLED=true
WEFTLYFLOW_TRACING_ENABLED=false
WEFTLYFLOW_OTEL_EXPORTER_OTLP_ENDPOINT=
WEFTLYFLOW_SENTRY_DSN=

# ---- user-defined expression variables ----
# Anything prefixed WEFTLYFLOW_VAR_* is exposed to expressions as $env.<name>.
# WEFTLYFLOW_VAR_COMPANY_NAME=Acme
